# Server-side environment variables (NOT prefixed with VITE_)
# Copy this to server/.env and fill in your keys
# These keys never touch the client bundle

BRAVE_SEARCH_API_KEY=your_brave_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# Premium encrypted search — must match VITE_SHARED_SECRET on the client
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHARED_SECRET=your_64_char_hex_string_here

# Port (optional, defaults to 3000)
PORT=3000
